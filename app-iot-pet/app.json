{
  "expo": {
    "name": "Tracky PeT",
    "slug": "app-iot-pet",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/images/LogoApp.png",
    "scheme": "appiotpet",
    "userInterfaceStyle": "automatic",
    "ios": {
      "supportsTablet": true,
      "config": {
        "googleMapsApiKey": "process.env.GOOGLE_MAPS_API_KEY"
      },
      "runtimeVersion": "1.0.0"
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/images/LogoApp.png",
        "backgroundColor": "#FFEEAA"
      },
      "config": {
        "googleMaps": {
          "apiKey": "process.env.GOOGLE_MAPS_API_KEY"
        }
      },
      "runtimeVersion": {
        "policy": "appVersion"
      },
      "package": "com.sroithongthae.appiotpet"
    },
    "plugins": [
      "expo-router",
      [
        "expo-splash-screen",
        {
          "image": "./assets/images/LogoApp.png",
          "imageWidth": 200,
          "resizeMode": "contain",
          "backgroundColor": "#FFEEAA"
        }
      ],
      "expo-font",
      [
        "expo-build-properties",
        {
          "android": {
            "extraProguardRules": "-keep class com.google.android.libraries.navigation.** { *; }"
          }
        }
      ],
      "expo-build-properties",
      "@react-native-community/datetimepicker"
    ],
    "experiments": {
      "typedRoutes": true
    },
    "extra": {
      "router": {},
      "eas": {
        "projectId": "dbc3aeeb-d1f0-4a9f-b73c-ed3b85a04163"
      }
    },
    "owner": "sroithongthae",
    "updates": {
      "url": "https://u.expo.dev/dbc3aeeb-d1f0-4a9f-b73c-ed3b85a04163"
    }
  }
}
